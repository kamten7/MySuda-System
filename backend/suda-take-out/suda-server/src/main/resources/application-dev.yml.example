# ===========================================
# application-dev.yml 配置模板
# 复制此文件为 application-dev.yml 并填入真实值
# WARNING: application-dev.yml 包含敏感信息，请勿提交到 Git！
#
# 配置方式（二选一）：
# 1. 直接在此文件填写真实值（本地开发）
# 2. 用根目录 .env 通过环境变量注入（Docker 部署），格式见 .env.example
# ===========================================

suda:
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    host: 你的数据库地址
    port: 3306
    database: sky_take_out
    username: 你的数据库用户名
    password: 你的数据库密码
  alioss:
    endpoint: 你的OSS Endpoint
    access-key-id: 你的阿里云AccessKeyId
    access-key-secret: 你的阿里云AccessKeySecret
    bucket-name: 你的OSS Bucket名称
  redis:
    host: 你的Redis地址
    port: 6379
    password: 你的Redis密码
    database: 1
  wechat:
    app-id: 你的微信AppId
    secret: 你的微信AppSecret
    mchid: 你的商户号
    mchSecret: 你的商户密钥
    privateKeyFilePath: /path/to/your/apiclient_key.pem
    apiV3Key: 你的APIv3密钥
    weChatPayCertFilePath: /path/to/your/apiclient_cert.pem
    notifyUrl: 你的支付回调地址
    refundNotifyUrl: 你的退款回调地址
  shop:
    address: 你的店铺地址
  baidu:
    ak: 你的百度地图AK
