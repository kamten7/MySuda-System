# ===========================================
# application-dev.yml 配置模板
# 复制此文件为 application-dev.yml 并填入真实值
# WARNING: application-dev.yml 包含敏感信息，请勿提交到 Git！
#
# 配置方式（二选一）：
# 1. 直接在此文件填写真实值（本地开发）
# 2. 用根目录 .env 通过环境变量注入（Docker 部署），格式见 .env.example
# ===========================================

suda:
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    host: 你的数据库地址
    port: 3306
    database: sky_take_out
    username: 你的数据库用户名
    password: 你的数据库密码
  minio:
    endpoint: http://你的MinIO地址:9010
    access-key: 你的MinIO访问密钥
    secret-key: 你的MinIO秘密密钥
    bucket-name: sky-take-out
  redis:
    host: 你的Redis地址
    port: 6379
    password: 你的Redis密码
    database: 1
  wechat:
    app-id: 你的微信AppId
    secret: 你的微信AppSecret
    mchid: 你的商户号
    mchSecret: 你的商户密钥
    privateKeyFilePath: /path/to/your/apiclient_key.pem
    apiV3Key: 你的APIv3密钥
    weChatPayCertFilePath: /path/to/your/apiclient_cert.pem
    notifyUrl: 你的支付回调地址
    refundNotifyUrl: 你的退款回调地址
  shop:
    address: 你的店铺地址
  baidu:
    ak: 你的百度地图AK

  # ===== DeepSeek 官方 API（管理端，LangChain4j）=====
  # 注册地址：https://platform.deepseek.com
  # 新用户赠送 500 万免费 token，deepseek-v4-flash 模型 $0.14/百万 token
  ai:
    deepseek:
      api-key: 你的DeepSeek_API_Key
      base-url: https://api.deepseek.com/v1
      model-name: deepseek-v4-flash

  # ===== DeepSeek 官方 API（管理端，LangChain4j）=====
  langchain4j:
    open-ai:
      chat-model:
        base-url: https://api.deepseek.com/v1
        api-key: 你的DeepSeek_API_Key
        model-name: deepseek-v4-flash
        timeout: 60000
      streaming-chat-model:
        base-url: https://api.deepseek.com/v1
        api-key: 你的DeepSeek_API_Key
        model-name: deepseek-v4-flash
        timeout: 60000

# ===========================================
# Spring AI — 用户端"小速"AI 点餐助手
# ⚠️ base-url 不带 /v1（OpenAiApi 内部自动拼接）
# ⚠️ 模型 deepseek-v4-flash（免费），不要用 deepseek-reasoner（付费）
# ===========================================
spring:
  ai:
    openai:
      api-key: 你的DeepSeek_API_Key
      chat:
        api-key: 你的DeepSeek_API_Key
        base-url: https://api.deepseek.com
        options:
          model: deepseek-v4-flash
          temperature: 0.7
          max-tokens: 2000
