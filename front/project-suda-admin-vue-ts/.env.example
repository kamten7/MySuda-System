# ===========================================
# 前端环境变量模板
# 复制此文件为 .env.development / .env.production / .env.staging 并填入真实值
# WARNING: .env.* 文件包含环境配置，请勿提交到 Git！
# ===========================================

# Base api
VUE_APP_BASE_API = '/api'

# 后端服务地址
VUE_APP_URL = 'http://localhost:8080/admin'

# WebSocket 地址
VUE_APP_SOCKET_URL = 'ws://localhost:8080/ws/'

# 删除权限 true=有
VUE_APP_DELETE_PERMISSIONS = true
