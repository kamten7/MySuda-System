# ============================================
# 环境变量配置（模板）
# 复制此文件为 .env 并填入你的真实值
# WARNING: .env 包含敏感信息，请勿提交到 Git！
# ============================================

# --- 数据库 ---
SUDA_DB_HOST=localhost
SUDA_DB_PORT=3306
SUDA_DB_DATABASE=sky_take_out
SUDA_DB_USERNAME=root
SUDA_DB_PASSWORD=你的数据库密码

# --- 阿里云 OSS ---
SUDA_ALIOSS_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
SUDA_ALIOSS_ACCESS_KEY_ID=你的阿里云AccessKeyId
SUDA_ALIOSS_ACCESS_KEY_SECRET=你的阿里云AccessKeySecret
SUDA_ALIOSS_BUCKET_NAME=你的OSS Bucket名称

# --- Redis ---
SUDA_REDIS_HOST=localhost
SUDA_REDIS_PORT=6379
SUDA_REDIS_PASSWORD=你的Redis密码
SUDA_REDIS_DATABASE=0

# --- 微信支付 ---
SUDA_WECHAT_APP_ID=你的微信AppId
SUDA_WECHAT_SECRET=你的微信AppSecret
SUDA_WECHAT_MCHID=你的商户号
SUDA_WECHAT_MCH_SECRET=你的商户密钥
SUDA_WECHAT_API_V3_KEY=你的APIv3密钥
SUDA_WECHAT_NOTIFY_URL=你的支付回调地址

# --- 百度地图 ---
SUDA_BAIDU_AK=你的百度地图AK
